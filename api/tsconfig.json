{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "typeRoots": ["../server/node_modules/@types", "../node_modules/@types"],
    "types": ["node"]
  },
  "include": ["./index.ts", "../server/src/**/*.ts"]
}
