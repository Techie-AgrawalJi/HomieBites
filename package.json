{
  "name": "homiebites",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm --prefix server install --legacy-peer-deps",
    "predev": "node scripts/free-dev-ports.cjs && timeout /t 2 /nobreak > nul",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "seed": "npm --prefix server run seed",
    "install:all": "npm install && npm --prefix client install && npm --prefix server install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  }
}

