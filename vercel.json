{
  "version": 2,
  "installCommand": "npm install && npm --prefix client install && npm --prefix server install --legacy-peer-deps",
  "buildCommand": "npm --prefix client run build",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}